# Rinomina questo file in .env e compila i valori
# Rename this file to .env and fill in the values

# OAuth Token dell'account bot queueBot (twitchtokengenerator.com)
# OAuth Token for the bot account queueBot (twitchtokengenerator.com)
TWITCH_OAUTH_TOKEN=oauth:your_token_here

# Canale Twitch dello streamer
# Streamer's Twitch channel
TWITCH_CHANNEL=your_channel_here

# Riot Games API
RIOT_API_KEY=RGAPI-your-key-here

# Riot ID dello streamer (nome + tag)
# Streamer's Riot ID (name + tag)
STREAMER_RIOT_NAME=YourName
STREAMER_RIOT_TAG=EUW
